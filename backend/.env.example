# Payload CMS Secret
# Generate a secure random string for production
PAYLOAD_SECRET=your-super-secret-payload-string-change-in-production

# Supabase PostgreSQL Connection (REQUIRED)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# ⚠️  This variable is REQUIRED - the application will not start without it!
# Get your connection string from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URI=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternative connection string for pooling (Transaction mode)
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Supabase API Configuration (if needed for direct API access)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Provider (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Admin Email for Notifications
ADMIN_EMAIL=shemamanase992@gmail.com

# Twilio WhatsApp Configuration
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# NOTE: For Twilio WhatsApp Sandbox:
# 1. Go to https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 2. Follow the instructions to join the sandbox
# 3. Send "join [your-sandbox-code]" to the Twilio WhatsApp number
# 4. Customers must also send the join code to receive messages

# Server Configuration
PORT=3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
